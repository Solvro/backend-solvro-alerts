# === Runtime & security ===
# SECRET_KEY=your-secret-key
DEBUG=True
# ALLOWED_HOSTS=alerts.solvro.pl,localhost,127.0.0.1
# Comma-separated origins (with scheme) trusted for CSRF, e.g.:
# CSRF_TRUSTED_ORIGINS=https://alerts.solvro.pl

# === Database ===
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=your_db_name
# DB_USER=your_db_user
# DB_PASSWORD=your_db_password
# DB_HOST=localhost
# DB_PORT=5432

# === Authentication ===
# SOLVRO_AUTH_CLIENT_ID=solvro-alerts
# SOLVRO_AUTH_CLIENT_SECRET=your-solvro-auth-client-secret
